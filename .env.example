# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Local (non-Docker): change host/user/password as needed
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/bd_ecommerce?schema=public"

# ─── Docker / Production PostgreSQL ──────────────────────────────────────────
# Used by docker-compose.prod.yml to configure the postgres container
POSTGRES_USER=ecom_user
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=bd_ecommerce

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# For Redis Cloud / managed Redis use a full URL instead:
# REDIS_URL=redis://:password@host:port

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_64_CHARS_MIN
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_SECRET
JWT_REFRESH_EXPIRES_IN=30d

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── SSL Commerz ─────────────────────────────────────────────────────────────
# Get from: https://developer.sslcommerz.com/
# Sandbox credentials for testing:
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_IS_LIVE=false   # set to true in production

# ─── bKash PGW ───────────────────────────────────────────────────────────────
# Get from: https://developer.bka.sh/
BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
# Sandbox base URL: https://tokenized.sandbox.bka.sh/v1.2.0-beta
# Production base URL: https://tokenized.pay.bka.sh/v1.2.0-beta
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_CALLBACK_URL=http://localhost:5000/api/payments/bkash/callback

# ─── SendGrid (Email) ─────────────────────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Your Shop BD

# ─── SMS Gateway ─────────────────────────────────────────────────────────────
# Option A — Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Option B — BulkSMSBD (local BD gateway, often cheaper)
# BULKSMSBD_API_KEY=your_api_key
# BULKSMSBD_SENDER_ID=your_sender_id

# Choose which SMS provider to use: "twilio" | "bulksmsbd"
SMS_PROVIDER=twilio

# ─── Admin Seed ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Super Admin
